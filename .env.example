# Retrieve your GA ID from your GA dashboard
GOOGLE_ANALYTICS_ID=G-XXXXXXX

# Optional tip jar (Ko-fi, Buy Me a Coffee, Patreon, GitHub Sponsors, …)
NEXT_PUBLIC_SUPPORT_TIP_URL=https://ko-fi.com/yourusername

# Slack incoming webhook for beta tester form submissions (server-only — do not use NEXT_PUBLIC_)
SLACK_BETA_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack app — react with :incoming_envelope: on a signup message to send the welcome email
# https://api.slack.com/apps → Event Subscriptions → https://www.pinporium.app/api/slack/events
# Bot event: reaction_added. Scopes: channels:history, groups:history, chat:write, reactions:read. Invite bot to beta channel.
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_BETA_CHANNEL_ID=C0123456789
# SLACK_BETA_THANKS_REACTION=incoming_envelope
# SLACK_BETA_THANKS_USER_IDS=U0123456789

# Optional: absolute origin for email image URLs (defaults to https://www.pinporium.app)
# EMAIL_ASSETS_BASE_URL=https://www.pinporium.app

# Resend — signup confirmation on apply; full welcome when you react on Slack (https://resend.com)
# Verify pinporium.app (or subdomain) in Resend, then use e.g. Pinporium <beta@pinporium.app>
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Pinporium <beta@pinporium.app>

# Cloudflare Turnstile (beta form spam protection) — https://dash.cloudflare.com/
# Test keys (always pass): site 1x00000000000000000000AA secret 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
